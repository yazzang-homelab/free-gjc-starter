# free-gjc-starter — 예시 환경변수 파일.
# 실제 키는 여기 말고 셸 환경변수(export / setx)에 넣는 걸 권장합니다.
# 이 파일을 복사해 .env 로 쓰더라도 .gitignore 가 커밋을 막아줍니다.

# 무료 서브에이전트 키 (본인 발급):
OPENROUTER_API_KEY=           # https://openrouter.ai/keys
GROQ_API_KEY=                 # https://console.groq.com/keys

# 메인 Gemini 는 키가 아니라 OAuth 로그인으로 씁니다 → free-gjc 실행 후 /login
